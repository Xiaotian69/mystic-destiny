/* pages/fortune/index.wxss */
.fortune-page {
  min-height: 100vh;
  background: #1A1033;
  color: #C8A951;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.placeholder__title {
  font-size: 44rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
}

.placeholder__hint {
  font-size: 26rpx;
  color: rgba(200, 169, 81, 0.6);
}
